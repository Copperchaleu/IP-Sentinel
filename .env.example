# Copy this file to .env before the first container start.
# Do not commit your real Telegram Bot token.

TG_TOKEN=123456:replace_me
MASTER_NODE_NAME=IP-Sentinel-Master
TZ=Asia/Shanghai

# Optional switches.
IS_OFFICIAL_GATEWAY=false
ENABLE_MASTER_OTA=false

# Set to true only when you intentionally want environment values to rewrite
# the saved /opt/ip_sentinel_master/master.conf in the Docker volume.
UPDATE_CONFIG_FROM_ENV=false
